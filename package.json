{
  "name": "portfolio-v3",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "husky && panda codegen",
    "dev": "rm -rf .next && next dev --webpack",
    "build": "panda codegen && next build --webpack && next-sitemap",
    "analyze": "cross-env ANALYZE=true next build --webpack",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "lint": "eslint .",
    "lint:staged": "lint-staged"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "overrides": {
      "@types/react": "19.2.14"
    }
  },
  "lint-staged": {
    "./src/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@giscus/react": "^3.0.0",
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "16.2.1",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-visually-hidden": "^1.1.0",
    "@types/mdx": "^2.0.13",
    "@vercel/analytics": "^2.0.0",
    "clsx": "^2.0.0",
    "date-fns": "^4.0.0",
    "embla-carousel-react": "^8.6.0",
    "gray-matter": "^4.0.3",
    "motion": "^12.38.0",
    "next": "16.2.1",
    "next-sitemap": "^4.1.8",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "^6.0.0",
    "reading-time": "^1.5.0",
    "rehype-pretty-code": "^0.14.0",
    "remark-frontmatter": "^5.0.0",
    "sharp": "^0.34.0",
    "shiki": "^4.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@eslint/js": "^9.0.0",
    "@next/bundle-analyzer": "16.2.1",
    "@pandacss/dev": "^1.9.1",
    "@types/node": "^25.0.0",
    "@types/react": "19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "cross-env": "^10.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "16.2.1",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.0.0",
    "postcss": "^8.4.24",
    "postcss-easing-gradients": "^3.0.1",
    "postcss-flexbugs-fixes": "^5.0.2",
    "postcss-preset-env": "^9.0.0",
    "prettier": "^3.0.0",
    "prettier-plugin-organize-imports": "^4.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.7.0"
  }
}
